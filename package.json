{
  "name": "codex-auto-runner",
  "version": "0.1.0",
  "private": true,
  "displayName": "Codex Auto Runner",
  "description": "A local Codex quota recovery runner that resumes active goal tasks when the 5-hour window recovers and keeps them moving toward the weekly limit.",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lay-quq/codex-auto-runner.git"
  },
  "homepage": "https://github.com/Lay-quq/codex-auto-runner#readme",
  "bugs": {
    "url": "https://github.com/Lay-quq/codex-auto-runner/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "car": "tsx apps/cli/src/index.ts",
    "web": "pnpm --filter @car/web dev",
    "web:build": "pnpm --filter @car/web build",
    "probe": "tsx tools/protocol-probe/src/index.ts",
    "probe:turn": "tsx tools/thread-turn-probe/src/index.ts",
    "schema:gen": "tsx scripts/generate-schema.ts",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run && pnpm --filter @car/persistence test"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  }
}
